{
  "name": "relayforge-ai",
  "private": true,
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @relayforge/web",
    "dev:worker": "npm run dev --workspace @relayforge/worker",
    "build:web": "npm run build --workspace @relayforge/web",
    "build:worker": "npm run build --workspace @relayforge/worker",
    "build": "npm run build:web && npm run build:worker",
    "typecheck:web": "npm run typecheck --workspace @relayforge/web",
    "typecheck:worker": "npm run typecheck --workspace @relayforge/worker",
    "typecheck": "npm run typecheck:web && npm run typecheck:worker"
  }
}

