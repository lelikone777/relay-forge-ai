# Frontend (apps/web/.env.local)
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8787

# Worker local vars (apps/worker/.dev.vars or Wrangler secrets)
ALLOWED_ORIGIN=*
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_HTTP_REFERER=https://your-pages-domain.pages.dev
OPENROUTER_APP_TITLE=RelayForge AI
RELAYFORGE_FORCE_DEMO=false

